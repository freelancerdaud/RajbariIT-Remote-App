{
    "productName": "RajbariIT Remote",
    "version": "1.0.0",
    "identifier": "com.rajbariit.remote",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "RajbariIT Remote",
                "width": 960,
                "height": 700,
                "minWidth": 700,
                "minHeight": 550,
                "resizable": true,
                "decorations": true,
                "transparent": false,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "windows": {
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}
